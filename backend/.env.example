# ============================================================================
# DATA PROVIDER KEYS
# ============================================================================
# Most data is served by a fallback chain. The two keys you almost certainly
# want are POLYGON_API_KEY (for prices) and FMP_API_KEY (for fundamentals).
# Without FMP, Holdings Intelligence "Fair Value" relies on Alpha Vantage's
# 25-call/day free tier, which gets rate-limited fast on a multi-ticker run.

# Market data: prices and history.
# Polygon free tier = 5 calls/min. https://polygon.io/
POLYGON_API_KEY=

# Fundamentals + market data fallback. STRONGLY RECOMMENDED.
# FMP free tier = 250 calls/day, covers PE/PB/EV-EBITDA/ROE/EPS/etc.
# Sign up at https://site.financialmodelingprep.com/developer/docs (60 seconds).
# Without this, the "VAL INPUTS" / "FAIR VALUE" columns will be sparse.
FMP_API_KEY=

# Fundamentals fallback + technicals enrichment. https://www.alphavantage.co/
# Free tier is 25/day - very tight. Only useful as a small-portfolio backup.
ALPHA_VANTAGE_API_KEY=

# Macro series (VIX, US10Y, DXY). Free at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# News fallback. https://newsapi.org/
NEWSAPI_API_KEY=

# Optional: self-hosted OpenBB Platform server. Leave blank if you don't run one.
# When set, OpenBB becomes the primary fundamentals source.
OPENBB_BASE_URL=
OPENBB_PROVIDER=yfinance
OPENBB_MACRO_PROVIDER=tradingeconomics

# Optional: macro calendar fallback. https://tradingeconomics.com/api/
TRADING_ECONOMICS_API_KEY=

# AI synthesis layer. Optional — system fails open without it.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-nano

# Required by SEC EDGAR per their fair-use policy. Use a real contact.
SEC_USER_AGENT=RiskPulse/1.0 support@example.com

# ============================================================================
# RUNTIME TUNABLES (defaults are sensible for a personal-project setup)
# ============================================================================
REQUEST_TIMEOUT_SECONDS=20
HISTORY_DAYS=120
NEWS_LIMIT=20
QUOTE_CACHE_TTL_SECONDS=120
HISTORY_CACHE_TTL_SECONDS=3600
TECHNICAL_CACHE_TTL_SECONDS=1800
MACRO_CACHE_TTL_SECONDS=1800
NEWS_CACHE_TTL_SECONDS=900
AI_CACHE_TTL_SECONDS=1800
ALPHA_VANTAGE_MAX_CALLS_PER_REQUEST=4
ALPHA_VANTAGE_TECHNICAL_CALLS_PER_TICKER=2
ALPHA_VANTAGE_TECHNICAL_ENRICHED_TICKERS=2
MAX_POSITIONS_FOR_RISK=5
MAX_POSITIONS_FOR_INTEL=8
MAX_TICKER_NEWS_SYMBOLS=5
TICKER_NEWS_PER_SYMBOL=5
